# ── Image Studio API key (REQUIRED) ──────────────────────────────────────────
# Your personal Image Studio /v1 key. Get one at:
#   https://studio.ross-developers.com/agents/mcp
# The server refuses to start without it. Keep it secret — never commit .env.
# Tip: try it with no signup using the watermarked sandbox key `isk_test_onelove`.
IMAGE_STUDIO_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Where generated PNGs are saved (default: <package>/outputs).
IMAGE_OUTPUT_DIR=
# Max seconds a generate/edit tool blocks polling before returning a job handle.
MCP_MAX_WAIT_S=900
